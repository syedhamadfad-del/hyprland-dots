.color-scheme {
    background: #282828;
    background-alt: #32302f;
    foreground: #ebdbb2;
    accent: #fb4934;
    selection: #3c3836;
    selection-background: #fbf1c7;
    border: #928374;
    border-color: #504945;
}

.item {
    highlight: #fabd2f;
}

# gruvbox color scheme for rofi
#
# original colors:
# Dark:   #282828 / #1d2021
# Light:  #fbf1c7
# Gray:   #a89984
# Red:    #fb4934
# Green:  #b8bb26
# Yellow: #fabd2f
# Blue:   #83a598
# Purple: #d3869b
# Aqua:   #8ec07c